<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">


<suite name="TestNG Regression Suite" verbose="3" parallel="tests"
	thread-count="3">

	<test name="OpenCart Test_Chrome">
		<parameter name="browser" value="chrome" />
		<parameter name="url"
			value="https://naveenautomationlabs.com/opencart/index.php?route=account/login" />
		<classes>
			<class name="testngsessions.OpenCartTest" />
		</classes>
	</test>

	<test name="OpenCart Test_Firefox">
		<parameter name="browser" value="firefox" />
		<parameter name="url"
			value="https://naveenautomationlabs.com/opencart/index.php?route=account/login" />
		<classes>
			<class name="testngsessions.OpenCartTest" />
		</classes>
	</test>

	<test name="OpenCart Test_edge">
		<parameter name="browser" value="edge" />
		<parameter name="url"
			value="https://naveenautomationlabs.com/opencart/index.php?route=account/login" />
		<classes>
			<class name="testngsessions.OpenCartTest" />
		</classes>
	</test>
	
	<test name="Orange HRM Test">
		<parameter name="browser" value="firefox" />
		<parameter name="url"
			value="https://orangehrm.com/en/contact-sales" />
		<classes>
			<class name="testngsessions.OrangeHRMTest" />
		</classes>
	</test>


	<test name="Google Test">
		<parameter name="browser" value="edge" />
		<parameter name="url" value="https://www.google.com/" />
		<classes>
			<class name="testngsessions.GoogleTest" />
		</classes>
	</test>


</suite>